# ── Supabase Connections ──────────────────────────────────────
# Transaction pooler — used by FastAPI/SQLAlchemy at runtime
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Direct connection — used for migrations and seed scripts
DATABASE_URL_DIRECT=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# ── POLARIS Flags ─────────────────────────────────────────────
POLARIS_PITCH_MODE=true
VITE_PITCH_MODE=true

# Generated PDS / Excel output (repo-relative when starting uvicorn from project root)
POLARIS_OUTPUT_DIR=api/generated

# ── Gemini (Required if PITCH_MODE=false) ─────────────────────
GOOGLE_GEMINI_API_KEY=your_key_here
GOOGLE_GEMINI_MODEL=gemini-2.5-flash
