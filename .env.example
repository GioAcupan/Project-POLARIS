# ── Supabase (required for API) ───────────────────────────────────────────
# Transaction pooler — FastAPI / SQLAlchemy at runtime (asyncpg, port 6543).
# Replace [PROJECT_REF] and [PASSWORD] with values from Supabase Dashboard → Settings → Database.
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Direct connection — migrations, psql, SQL Editor only (not read by api/db.py).
# DATABASE_URL_DIRECT=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── POLARIS ────────────────────────────────────────────────────────────────
POLARIS_PITCH_MODE=true

# Generated PDS / Excel output directory (must match api/routers/downloads.py and main.py).
# Linux/Docker (blueprint): /var/polaris/generated
# Local Windows/macOS: use a repo path, e.g. api/generated or an absolute path.
# POLARIS_OUTPUT_DIR=api/generated

# ── Gemini (only when POLARIS_PITCH_MODE=false) ───────────────────────────
# GOOGLE_GEMINI_API_KEY=
